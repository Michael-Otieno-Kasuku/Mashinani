from django import forms
from .models import BursaryApplication

class ApplicationForm(forms.ModelForm):
    class Meta:
        model = BursaryApplication
        fields = ['national_id_number', 'student_registration_number', 'institution', 'institution_account_number', 'financial_year']
        widgets = {
            'institution': forms.Select(attrs={'class': 'blue-border'}),
            'national_id_number': forms.TextInput(attrs={'class': 'blue-input-box'}),
            'student_registration_number': forms.TextInput(attrs={'class': 'blue-input-box'}),
            'institution_account_number': forms.TextInput(attrs={'class': 'blue-input-box'}),
        }

class ProgressTrackingForm(forms.Form):
    serial_number = forms.CharField(max_length=8, help_text="Enter the 8-alphanumeric serial number")

