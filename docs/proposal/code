# models.py
from django.db import models

class Institution(models.Model):
    name = models.CharField(max_length=255)

class BursaryApplication(models.Model):
    national_id_number = models.CharField(max_length=20, help_text="Enter a valid National ID Number")
    student_registration_number = models.CharField(max_length=20, help_text="Enter a valid Student Registration Number")
    institution = models.ForeignKey(Institution, on_delete=models.CASCADE, help_text="Choose the Tertiary Institution")
    institution_account_number = models.CharField(max_length=20, help_text="Enter a valid Institution Account Number")
    financial_year = models.CharField(max_length=10, help_text="Enter the financial year")
    serial_number = models.CharField(max_length=8, help_text="Auto-generated serial number")
    date_submitted = models.DateTimeField(auto_now_add=True)
    amount_disbursed = models.DecimalField(max_digits=10, decimal_places=2, null=True, blank=True, help_text="Amount disbursed in Ksh")
    date_disbursed = models.DateTimeField(null=True, blank=True, help_text="Date of disbursement")

